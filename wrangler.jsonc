{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "omca",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "omca",
			"database_id": "7be107e8-463f-4cab-8c8f-dfd2101a3aec",
		}
	]
}